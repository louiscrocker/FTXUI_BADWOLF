# Ignore all the files, except the ones we expect.
# See https://jasonstitt.com/gitignore-whitelisting-patterns
*
!*/

# Ignore build directories generated by default MSVC CMake integration
# (otherwise causes terribly slow indexing)
out/

# Allowed top-level files:
!.clang-format
!.clang-tidy
!.gitignore
!CHANGELOG.md
!CMakeLists.txt
!LICENSE
!README.md
!codecov.yml
!flake.lock
!flake.nix
!ftxui.pc.in
!iwyu.imp
!WORKSPACE.bazel
!BUILD.bazel
!MODULE.bazel
!.bazelrc
!.bazelignore

# .github directory:
!.github/**/*.yaml
!.github/**/*.yml
!.github/**/*.md

# cmake directory:
!cmake/**/*.in
!cmake/**/*.cmake

# bazel directory:
!bazel/**/*.bzl
!.bcr/*
!bazel/test/*.bazel
!bazel/test/*.bazelrc
!bazel/test/*.cpp
!bazel/test/*.md

# doc directory:
!doc/**/Doxyfile.in
!doc/**/*.txt
!doc/**/*.css
!doc/**/*.html

# docs/ — GitHub Pages site:
!docs/**/*.html
!docs/**/*.css
!docs/**/*.js
!docs/**/*.yml
!docs/**/*.md
!docs/.nojekyll
!doc/**/*.xml
!doc/**/*.md
!doc/*.md

# examples directory:
!examples/**/*.cpp
!examples/**/*.css
!examples/**/*.geojson
!examples/**/*.hpp
!examples/**/*.html
!examples/**/*.html.disabled
!examples/**/*.ipp
!examples/**/*.js
!examples/**/*.mjs
!examples/**/*.py
!examples/**/*.txt

# include directory:
!include/ftxui/**/*.hpp
!include/ftxui/**/*.cpp
!include/ftxui-c/**/*.h

# src directory:
!src/ftxui/*.cppm
!src/ftxui/**/*.hpp
!src/ftxui/**/*.cpp
!src/ftxui/**/*.cppm
!src/ftxui_c/**/*.cpp
!src/ftxui_c/**/*.c

# tools directory:
!tools/**/*.sh
!tools/**/*.py
!tools/**/*.cpp
!tools/ftxui
!tools/badwolf

# registry directory:
!registry/**/*.json
!registry/**/*.hpp
!registry/**/*.md

# packaging directory:
!packaging/**/*.cmake
!packaging/**/*.json
!packaging/**/*.rb
!packaging/**/*.py
!packaging/**/*.txt
!packaging/**/*.md
!packaging/debian/control

# dist directory:
!dist/**/*.hpp
!dist/**/*.cpp
!dist/**/*.md

# apps directory:
!apps/**/*.cpp
!apps/**/*.hpp
!apps/**/*.cmake
!apps/**/*.md
!apps/CMakeLists.txt

# bindings directory:
!bindings/**/*.py
!bindings/**/*.pyi
!bindings/**/*.cpp
!bindings/**/*.hpp
!bindings/**/*.toml
!bindings/**/*.cfg
!bindings/**/*.txt
!bindings/**/*.md
!bindings/**/*.rs
!bindings/**/*.toml
!bindings/rust/src/*.rs
build/

# python directory (pybind11 bindings package):
!python/src/**/*.cpp
!python/pyftxui/**/*.py
!python/pyftxui/**/*.pyi
!python/**/*.toml
!python/setup.py
!python/examples/**/*.py
